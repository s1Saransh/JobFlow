# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/jobflow

# ─── JWT Authentication ──────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=30d

# ─── Client ──────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
